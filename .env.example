# ─── Base de données ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://kado:kado_dev_password@localhost:5432/kado
REDIS_URL=redis://:kado_redis_password@localhost:6379

# ─── Auth JWT RS256 ───────────────────────────────────────────────────────────
# Générer : openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Générer : openssl rand -hex 32
HMAC_VOUCHER_SECRET=change_me_32_bytes_hex_string_here_0000

# ─── SMS ──────────────────────────────────────────────────────────────────────
NEXAH_API_KEY=nxh_live_change_me
TWILIO_ACCOUNT_SID=ACchange_me
TWILIO_AUTH_TOKEN=change_me
SMS_FROM_NUMBER=+221XXXXXXXXX

# ─── Paiements ────────────────────────────────────────────────────────────────
WAVE_API_KEY=wave_live_change_me
WAVE_WEBHOOK_SECRET=change_me_32_bytes_hex_string_here_0001
OM_API_KEY=change_me
OM_WEBHOOK_SECRET=change_me_32_bytes_hex_string_here_0002

# ─── EME partenaire ───────────────────────────────────────────────────────────
EME_PARTNER_API_URL=https://api.partenaire-eme.sn/v1
EME_PARTNER_API_KEY=change_me

# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
COMMISSION_RATE=0.02
SENTRY_DSN=
