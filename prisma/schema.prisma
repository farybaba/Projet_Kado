// KaDo — Schéma Prisma
// Règles absolues :
//  - Montants TOUJOURS en centimes FCFA (Int) — JAMAIS Float
//  - LedgerEntry : INSERT ONLY — pas d'updatedAt

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Railway deployment fix
  directUrl = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  BENEFICIARY
  MERCHANT
  COMPANY_ADMIN
  COMPANY_VIEWER
  ADMIN
}

enum VoucherStatus {
  PENDING
  ISSUED
  PARTIAL
  USED
  EXPIRED
  CANCELLED
}

enum VoucherType {
  GIFT_VOUCHER
  MEAL_TICKET
  TRANSPORT
  BONUS
}

enum CompanyStatus {
  PENDING_KYB
  ACTIVE
  SUSPENDED
}

enum MerchantStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum MerchantCategory {
  GENERAL
  FOOD
  MOBILITY
  HEALTH
  RETAIL
  EDUCATION
}

enum SaaSPlan {
  STANDARD
  PREMIUM
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum LedgerEntryType {
  ISSUE
  REDEEM
  PARTIAL_REDEEM
  EXPIRE
  CANCEL
  SETTLE
  SAAS_REVENUE
  PROVISION
}

enum WebhookProvider {
  WAVE
  ORANGE_MONEY
}

enum WebhookStatus {
  RECEIVED
  PROCESSED
  FAILED
}

// ─── Modèles ──────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  phone        String?   @unique
  email        String?   @unique
  passwordHash String?
  firstName    String?
  lastName     String?
  role         UserRole
  companyId    String?
  merchantId   String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  company      Company?  @relation(fields: [companyId], references: [id])
  merchant     Merchant? @relation(fields: [merchantId], references: [id])
  vouchers     Voucher[] @relation("BeneficiaryVouchers")
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique  // SHA-256 du refresh token
  userId    String
  family    String   // Pour détecter la réutilisation
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Company {
  id          String        @id @default(uuid())
  name        String
  siren       String?       @unique
  status      CompanyStatus @default(PENDING_KYB)
  plan        SaaSPlan      @default(STANDARD)
  phone       String?
  email       String?
  address     String?
  logoUrl     String?
  provisionBalance Int      @default(0)  // centimes FCFA
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  users       User[]
  vouchers    Voucher[]
  invitations Invitation[]
  ledgerEntries LedgerEntry[]

  @@map("companies")
}

model Merchant {
  id          String          @id @default(uuid())
  name        String
  phone       String?         @unique
  email       String?
  category    MerchantCategory @default(GENERAL)
  status      MerchantStatus  @default(PENDING)
  address     String?
  logoUrl     String?
  wavePhone   String?         // Numéro Wave pour reversement
  omPhone     String?         // Numéro Orange Money
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  users         User[]
  transactions  VoucherTransaction[]
  settlements   MerchantSettlement[]
  ledgerEntries LedgerEntry[]
  webhookLogs   WebhookLog[]

  @@map("merchants")
}

model Voucher {
  id               String        @id @default(uuid())
  code             String        @unique  // UUID QR — différent de id
  qrData           String        // JSON signé HMAC-SHA256
  nominalValue     Int           // centimes FCFA — JAMAIS Float
  remainingValue   Int           // centimes FCFA
  status           VoucherStatus
  type             VoucherType   @default(GIFT_VOUCHER)
  companyId        String
  beneficiaryPhone String
  beneficiaryId    String?
  expiresAt        DateTime      // défaut J+180
  scheduledAt      DateTime?     // émission programmée
  emeConfirmedAt   DateTime?     // null = PENDING, renseigné = ISSUED actif
  note             String?       @db.VarChar(200)
  issuedAt         DateTime      @default(now())
  lastUsedAt       DateTime?
  createdAt        DateTime      @default(now())

  company          Company       @relation(fields: [companyId], references: [id])
  beneficiary      User?         @relation("BeneficiaryVouchers", fields: [beneficiaryId], references: [id])
  transactions     VoucherTransaction[]
  ledgerEntries    LedgerEntry[]

  @@map("vouchers")
}

model VoucherTransaction {
  id          String   @id @default(uuid())
  voucherId   String
  merchantId  String
  amount      Int      // centimes FCFA — montant débité
  commission  Int      // centimes FCFA — 2% KaDo
  netAmount   Int      // centimes FCFA — amount - commission
  reference   String   @unique  // clé d'idempotence
  createdAt   DateTime @default(now())

  voucher     Voucher  @relation(fields: [voucherId], references: [id])
  merchant    Merchant @relation(fields: [merchantId], references: [id])

  @@map("voucher_transactions")
}

model MerchantSettlement {
  id          String   @id @default(uuid())
  merchantId  String
  amount      Int      // centimes FCFA
  reference   String   @unique  // SETTLE-{merchantId}-{yyyyMMdd}
  settledAt   DateTime @default(now())
  waveRef     String?
  omRef       String?

  merchant    Merchant @relation(fields: [merchantId], references: [id])

  @@map("merchant_settlements")
}

// INSERT ONLY — aucun UPDATE ni DELETE après création
model LedgerEntry {
  id            String          @id @default(uuid())
  type          LedgerEntryType
  debitAccount  String          // ex: PROVISION_COMPANY:uuid
  creditAccount String          // ex: VOUCHER_LIABILITY:uuid
  amount        Int             // centimes FCFA — toujours positif
  voucherId     String?
  merchantId    String?
  companyId     String?
  userId        String?
  reference     String          @unique  // clé d'idempotence UUID
  metadata      Json?
  createdAt     DateTime        @default(now())
  // PAS de updatedAt — INSERT ONLY

  voucher       Voucher?        @relation(fields: [voucherId], references: [id])
  merchant      Merchant?       @relation(fields: [merchantId], references: [id])
  company       Company?        @relation(fields: [companyId], references: [id])

  @@map("ledger_entries")
}

model Invitation {
  id          String           @id @default(uuid())
  token       String           @unique  // UUID signé, TTL 7 jours
  phone       String?
  email       String?
  firstName   String?
  lastName    String?
  poste       String?
  departement String?
  companyId   String
  status      InvitationStatus @default(PENDING)
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime         @default(now())

  company     Company          @relation(fields: [companyId], references: [id])

  @@map("invitations")
}

model OtpAttempt {
  id        String   @id @default(uuid())
  phone     String
  attempts  Int      @default(0)
  blockedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([phone])
  @@map("otp_attempts")
}

model WebhookLog {
  id          String          @id @default(uuid())
  provider    WebhookProvider
  reference   String          @unique  // id de l'événement côté Wave/OM
  rawBody     String          @db.Text  // JSON brut reçu
  status      WebhookStatus   @default(RECEIVED)
  amount      Int?            // centimes FCFA si extrait
  merchantId  String?
  receivedAt  DateTime        @default(now())
  processedAt DateTime?
  error       String?         @db.Text

  merchant    Merchant?       @relation(fields: [merchantId], references: [id])

  @@index([status, receivedAt])
  @@index([provider, receivedAt])
  @@map("webhook_logs")
}
